{
  "name": "flock-dodger",
  "version": "1.0.0",
  "description": "Privacy-first ALPR / surveillance awareness routing (PWA + Android)",
  "private": true,
  "scripts": {
    "build": "node scripts/sync-www.mjs",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "android": "npm run cap:sync && npx cap open android",
    "serve": "npx --yes serve www -l 8080"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/geolocation": "^6.1.0",
    "@capacitor/splash-screen": "^6.0.3",
    "@capacitor/status-bar": "^6.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0"
  }
}
